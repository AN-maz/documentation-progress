<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style type="text/tailwindcss">
        @theme {
            /* Warna tetap menggunakan biru, namun variabel kita biarkan tetap agar kompatibel */
            --color-oxi-light: #0051D2; 
            --color-oxi-dark: #001A57;
            --color-fintech-bg: #0B0E14;
            --color-fintech-card: #1C2127;
        }
    </style>
    <title>Dashboard | shopeGen</title>
</head>

<body class="bg-fintech-bg text-white font-sans min-h-screen">

    <div class="max-w-6xl mx-auto md:py-4">

        <header
            class="flex justify-between items-center px-4 py-6 md:px-0 mb-2 border-b border-gray-800 md:border-none">
            <div class="flex items-center gap-3">
                <div
                    class="bg-gradient-to-br from-oxi-light to-blue-400 w-10 h-10 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/30">
                    <i class="fa-solid fa-bag-shopping text-white text-lg"></i>
                </div>
                <h1 class="text-2xl font-black tracking-tight">shope<span class="text-oxi-light">Gen</span></h1>
            </div>

            <div class="flex items-center gap-3">
                <div class="text-right hidden md:block">
                    <p class="text-xs text-gray-400 font-medium">Premium Member</p>
                    <h2 class="text-sm font-bold">
                        <%= user.username %>
                    </h2>
                </div>
                <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-oxi-light">
                    <img src="https://ui-avatars.com/api/?name=<%= user.username %>&background=0051D2&color=fff"
                        alt="Profile">
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 px-4 md:px-0">

            <div class="md:col-span-5 space-y-6">

                <div class="flex justify-between items-center pt-2">
                    <h2 class="text-lg font-bold">Dompet shopeGen</h2>
                    <button
                        class="bg-fintech-card px-4 py-2 rounded-2xl text-sm font-semibold flex items-center gap-2 hover:bg-gray-800 transition">
                        <i class="fa-solid fa-gift text-oxi-light"></i> Promo
                    </button>
                </div>

                <div
                    class="bg-gradient-to-br from-oxi-dark to-oxi-light p-8 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
                    <div class="relative z-10">
                        <p class="text-white/70 text-sm mb-2">Total Saldo</p>
                        <h1 class="text-4xl md:text-5xl font-bold mb-2">
                            Rp <%= user.shopeepay_saldo.toLocaleString('id-ID') %>
                        </h1>
                        <p class="text-green-300 text-sm font-medium">
                            <i class="fa-solid fa-arrow-up"></i> +16,86% <span class="text-white/50 ml-1">vs bulan
                                lalu</span>
                        </p>
                    </div>
                    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
                </div>

                <div class="grid grid-cols-4 gap-3">
                    <button
                        class="bg-fintech-card aspect-square rounded-3xl flex flex-col items-center justify-center gap-2 hover:bg-oxi-light transition-colors">
                        <i class="fa-solid fa-paper-plane text-xl"></i>
                        <span class="text-xs">Kirim</span>
                    </button>
                    <button
                        class="bg-fintech-card aspect-square rounded-3xl flex flex-col items-center justify-center gap-2 hover:bg-oxi-light transition-colors">
                        <i class="fa-solid fa-wallet text-xl"></i>
                        <span class="text-xs">Terima</span>
                    </button>
                    <button
                        class="bg-fintech-card aspect-square rounded-3xl flex flex-col items-center justify-center gap-2 hover:bg-oxi-light transition-colors">
                        <i class="fa-solid fa-plus text-xl"></i>
                        <span class="text-xs">Top Up</span>
                    </button>
                    <button
                        class="bg-fintech-card aspect-square rounded-3xl flex flex-col items-center justify-center gap-2 hover:bg-oxi-light transition-colors">
                        <i class="fa-solid fa-ellipsis text-xl"></i>
                        <span class="text-xs">Lainnya</span>
                    </button>
                </div>
            </div>

            <div class="md:col-span-7 space-y-6">

                <div class="bg-fintech-card/30 rounded-[2.5rem] p-6 md:p-8">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-xl font-bold">Aktivitas Terakhir</h3>
                        <i
                            class="fa-solid fa-magnifying-glass text-gray-500 cursor-pointer hover:text-white transition"></i>
                    </div>

                    <div class="space-y-6">
                        <% transactions.forEach(item=> { %>
                            <div class="flex justify-between items-center group cursor-pointer">
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 bg-fintech-card rounded-2xl flex items-center justify-center text-2xl group-hover:bg-oxi-light transition-colors">
                                        <%= item.icon %>
                                    </div>
                                    <div>
                                        <h4 class="font-bold tracking-wide">
                                            <%= item.name %>
                                        </h4>
                                        <p class="text-xs text-gray-400">
                                            <%= item.corp %>
                                        </p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="font-bold">
                                        <%= item.amount %>
                                    </p>
                                    <p class="text-xs <%= item.color %> font-medium">
                                        <%= item.change %>
                                    </p>
                                </div>
                            </div>
                            <% }); %>
                    </div>

                    <div class="mt-10 pt-8 border-t border-gray-800">
                        <h3 class="text-lg font-bold mb-4 text-oxi-light">Beli Lagi (Flash Sale)</h3>
                        <form action="/checkout" method="POST" class="space-y-4">
                            <input type="hidden" name="total_harga" value="750000">
                            <div
                                class="bg-fintech-bg p-4 rounded-2xl flex justify-between items-center border border-gray-800">
                                <div class="flex items-center gap-3">
                                    <span class="text-2xl">👟</span>
                                    <span class="text-sm font-medium">Sepatu Lari shopeGen X1</span>
                                </div>
                                <span class="font-bold text-red-400">Rp 750.000</span>
                            </div>
                            <textarea name="kirim_ke" rows="2" required
                                class="w-full bg-fintech-bg border border-gray-800 rounded-2xl p-4 text-sm focus:outline-none focus:border-oxi-light transition-colors"
                                placeholder="Masukkan Alamat Pengiriman Lengkap..."></textarea>
                            <button type="submit"
                                class="w-full bg-white text-black font-bold py-4 rounded-2xl hover:bg-oxi-light hover:text-white transition-all shadow-lg">
                                Konfirmasi Pembayaran
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>

</html>