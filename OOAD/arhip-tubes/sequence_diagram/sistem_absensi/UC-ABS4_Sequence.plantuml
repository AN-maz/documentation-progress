@startuml
autonumber
skinparam style strictuml

actor HR
boundary "Dashboard Geofencing" as Form
control "Control Keamanan" as Ctrl
entity "Database Absensi" as DB

activate HR
HR -> Form: Masuk ke modul "Manajemen Geofencing & Fraud"
activate Form
HR -> Form: Meninjau titik koordinat pusat dan radius batas aman
Form -> Ctrl: Mengirim parameter filter
activate Ctrl

Ctrl -> DB: Meminta data log koordinat absen harian
activate DB
DB --> Ctrl: Mengembalikan sekumpulan data log
deactivate DB
Ctrl -> Ctrl: Menjalankan background service menyaring log koordinat

alt [Terdeteksi Aplikasi Fake GPS / Mock Location]
    Ctrl -> DB: Memblokir absen & menandai "Indikasi Fraud"
    activate DB
    DB --> Ctrl: Status terupdate
    deactivate DB
    Ctrl --> Form: Meneruskan peringatan fraud
    Form --> HR: Menampilkan peringatan instan ke layar HR
else [Aman / Tidak Terdeteksi]
    Ctrl --> Form: Mengembalikan log bersih
    Form --> HR: Menampilkan laporan log berstatus "Aman/Clean"
    HR -> Form: Menyetujui log laporan kehadiran valid
    Form -> Ctrl: Mengirim persetujuan
    Ctrl -> DB: Mengubah status log menjadi "Disetujui"
    activate DB
    DB --> Ctrl: Konfirmasi pembaruan log
    deactivate DB
    Ctrl --> Form: Konfirmasi sukses
    Form --> HR: Menampilkan notifikasi persetujuan berhasil
end

deactivate Ctrl
deactivate Form
deactivate HR
@enduml