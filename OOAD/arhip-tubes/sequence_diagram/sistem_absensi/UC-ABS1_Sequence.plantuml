@startuml
autonumber
skinparam style strictuml

actor HR
actor Karyawan
boundary "Modul Pendaftaran" as Form
control "Control Biometrik" as Ctrl
entity "Database Karyawan" as DB

activate HR
HR -> Form: Masuk ke modul "Mendaftarkan Wajah & NIP"
activate Form
HR -> Form: Menginputkan NIP, nama lengkap, dan divisi
HR -> Form: Mengaktifkan sensor kamera pemindai
Form -> Ctrl: Memulai sesi pemindaian
activate Ctrl

activate Karyawan
Karyawan -> Form: Memposisikan wajah di depan kamera
Form -> Ctrl: Mengirim tangkapan gambar wajah
Ctrl -> Ctrl: Memetakan struktur unik titik wajah

alt [Kualitas Jepretan Buruk (Gelap/Blur)]
    Ctrl --> Form: Mengembalikan error kualitas
    Form --> HR: Menampilkan pesan peringatan & menolak proses
else [Kualitas Baik (Jelas)]
    Ctrl --> Form: Menampilkan preview wajah berhasil
    HR -> Form: Menekan tombol "Simpan Profil"
    Form -> Ctrl: Meminta penyimpanan data
    Ctrl -> DB: Mengunci data biometrik dan NIP
    activate DB
    DB --> Ctrl: Konfirmasi penyimpanan berhasil
    deactivate DB
    Ctrl --> Form: Mengembalikan status sukses
    Form --> HR: Menampilkan notifikasi berhasil disimpan
end

deactivate Karyawan
deactivate Ctrl
deactivate Form
deactivate HR
@enduml