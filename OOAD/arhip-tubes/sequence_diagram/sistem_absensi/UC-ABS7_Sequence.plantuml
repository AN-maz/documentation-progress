@startuml
autonumber
skinparam style strictuml

actor Karyawan
boundary "Web Browser iOS" as Form
control "Control Web" as Ctrl
entity "Server Absensi" as DB

activate Form
Form -> Form: Menampilkan halaman web presensi responsif
Form -> Karyawan: Meminta izin akses kamera dan lokasi

activate Karyawan
alt [Izin Ditolak / Blocked]
    Karyawan --> Form: Menolak izin akses
    Form --> Karyawan: Menampilkan pesan "Akses Lokasi Ditolak"
    Form -> Form: Membatalkan proses pengiriman data absensi
else [Izin Diberikan / Allowed]
    Karyawan --> Form: Memberikan izin akses
    Karyawan -> Form: Mengambil foto selfie
    Form -> Ctrl: Meneruskan gambar & meminta titik GPS
    activate Ctrl
    Ctrl -> Ctrl: Memperoleh koordinat GPS perangkat
    Ctrl -> DB: Mengirimkan data absensi ke server
    activate DB
    DB --> Ctrl: Mengonfirmasi penyimpanan data
    deactivate DB
    Ctrl --> Form: Meneruskan status keberhasilan
    Form --> Karyawan: Menampilkan notifikasi presensi berhasil
    deactivate Ctrl
end

deactivate Form
deactivate Karyawan
@enduml