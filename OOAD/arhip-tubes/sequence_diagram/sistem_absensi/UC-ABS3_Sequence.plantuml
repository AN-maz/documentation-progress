@startuml
autonumber
skinparam style strictuml

actor Sales
boundary "Aplikasi VisitTrack" as Form
control "Control Absensi" as Ctrl
entity "Database Absensi" as DB

activate Sales
Sales -> Form: Membuka sistem absensi dari perangkat lapangan
activate Form
Sales -> Form: Memilih menu "Public Absen"
Form -> Ctrl: Meminta inisiasi Public Absen
activate Ctrl
Ctrl --> Form: Menginstruksikan akses kamera & GPS
Form --> Sales: Meminta ambil selfie & mengunci GPS
Sales -> Form: Mengambil selfie terkini
Form -> Ctrl: Mengirim data foto & koordinat GPS
Ctrl -> Ctrl: Memverifikasi lokasi koordinat GPS

alt [Di Luar Cakupan Penugasan / Tidak]
    Ctrl --> Form: Mengirim status penolakan
    Form --> Sales: Menolak pengajuan absen & menampilkan peringatan
else [Dalam Cakupan Penugasan / Ya]
    Ctrl -> DB: Menyimpan log absensi sebagai "Hadir Dinas Luar"
    activate DB
    DB --> Ctrl: Konfirmasi penyimpanan berhasil
    deactivate DB
    Ctrl --> Form: Mengembalikan status sukses
    Form --> Sales: Menampilkan notifikasi absen berhasil
end

deactivate Ctrl
deactivate Form
deactivate Sales
@enduml