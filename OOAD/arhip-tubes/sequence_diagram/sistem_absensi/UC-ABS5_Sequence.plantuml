@startuml
autonumber
skinparam style strictuml

actor Karyawan
boundary "Terminal Lobi" as Form
control "Control Biometrik" as Ctrl
entity "Database Karyawan" as DB

Form -> Ctrl: Meminta inisiasi terminal
activate Ctrl
Ctrl --> Form: Mengaktifkan kamera pemindai wajah
activate Form
deactivate Ctrl

activate Karyawan
Karyawan -> Form: Memposisikan wajah di dalam area pemindaian
Form -> Ctrl: Mengirim data pindaian wajah
activate Ctrl
Ctrl -> DB: Meminta pencocokan data biometrik
activate DB
DB --> Ctrl: Mengembalikan persentase kecocokan wajah
deactivate DB

alt [Kecocokan di bawah ambang batas (<95%)]
    Ctrl --> Form: Mengirim status wajah tidak cocok
    Form --> Karyawan: Menampilkan pesan "Wajah Tidak Dikenali"
    Form --> Karyawan: Diminta mengulangi proses pemindaian
else [Kecocokan di atas ambang batas (>=95%)]
    Ctrl -> Ctrl: Set status menjadi "Terverifikasi"
    Ctrl --> Form: Mengembalikan status "Terverifikasi" ke Base Case
    Form --> Karyawan: Menampilkan notifikasi terverifikasi
end

deactivate Ctrl
deactivate Form
deactivate Karyawan
@enduml