@startuml
autonumber
skinparam style strictuml

actor Karyawan
boundary "Menu Presensi" as Form
control "Control Presensi" as Ctrl
entity "Database Karyawan" as DB

activate Karyawan
Karyawan -> Form: Mengakses sistem absensi
activate Form
Karyawan -> Form: Memilih menu "Lakukan Presensi" & status (Masuk/Pulang)
Form -> Ctrl: Mengirim request presensi awal
activate Ctrl
Ctrl -> DB: Memeriksa status keaktifan akun karyawan
activate DB
DB --> Ctrl: Mengembalikan status akun
deactivate DB

alt [Akun Tidak Aktif / Terdaftar]
    Ctrl --> Form: Mengirim instruksi blokir
    Form --> Karyawan: Memblokir akses & menampilkan pesan error
else [Akun Aktif]
    Ctrl --> Form: Mengizinkan akses
    Form --> Karyawan: Meminta verifikasi kehadiran
    Karyawan -> Form: Menyelesaikan verifikasi kehadiran\n(Memicu Extend Wajah/App)
    Form -> Ctrl: Meneruskan data verifikasi
    Ctrl -> DB: Mencatat timestamp real-time presensi
    activate DB
    DB --> Ctrl: Konfirmasi pencatatan berhasil
    deactivate DB
    Ctrl --> Form: Status presensi sukses
    Form --> Karyawan: Menampilkan notifikasi berhasil
end

deactivate Ctrl
deactivate Form
deactivate Karyawan
@enduml