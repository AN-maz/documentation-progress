@startuml
autonumber
skinparam style strictuml

actor Sales
boundary "Aplikasi VisitTrack" as Form
control "Control Lokasi" as Ctrl
entity "Database VisitTrack" as DB

activate Sales
Sales -> Form: Memilih menu "Catat Kunjungan"
activate Form
Form -> Ctrl: Meminta inisiasi deteksi lokasi
activate Ctrl
Ctrl -> Ctrl: Mendeteksi lokasi GPS & koneksi internet

alt [Sensor GPS dan Internet Tidak Aktif (Exception)]
    Ctrl --> Form: Status deteksi gagal
    Form --> Sales: Menampilkan pesan kesalahan & Batal
else [Aktif / Berhasil]
    alt [Lokasi Tidak Terdeteksi Otomatis (Alternate)]
        Ctrl --> Form: Status perlu input manual
        Form --> Sales: Meminta penentuan titik manual
        Sales -> Form: Menentukan titik lokasi secara manual pada peta
        Form -> Ctrl: Meneruskan data koordinat manual
    else [Lokasi Terdeteksi Otomatis]
        Ctrl --> Form: Data koordinat & alamat terdeteksi
    end
    
    Form --> Sales: Menampilkan titik koordinat dan alamat pada peta
    Sales -> Form: Menekan tombol "Simpan Koordinat"
    Form -> Ctrl: Mengirim request simpan data
    
    Ctrl -> DB: Menyimpan data koordinat kunjungan
    activate DB
    DB --> Ctrl: Konfirmasi data tersimpan
    deactivate DB
    
    Ctrl --> Form: Status penyimpanan sukses
    Form --> Sales: Menampilkan notifikasi berhasil
end

deactivate Ctrl
deactivate Form
deactivate Sales
@enduml