@startuml
autonumber
skinparam style strictuml

actor "Calon Pelanggan" as Cust
actor Sales
boundary "Form Prospek" as Form
control "Control Prospek" as Ctrl
entity "Database VisitTrack" as DB

activate Cust
activate Sales
Sales -> Cust: Mewawancarai calon pelanggan
Cust --> Sales: Menyampaikan kondisi internet & keluhan
deactivate Cust

Sales -> Form: Membuka formulir pendataan prospek
activate Form
Sales -> Form: Memasukkan keluhan & kategori status prospek
Form -> Ctrl: Mengirim data form prospek
activate Ctrl
Ctrl -> Ctrl: Memvalidasi kelengkapan data prospek

alt [Data Prospek Tidak Lengkap (Exception)]
    Ctrl --> Form: Menolak penyimpanan
    Form --> Sales: Meminta melengkapi data yang kurang
    Sales -> Form: Melengkapi formulir data
else [Data Lengkap]
    alt [Kategori Status "Hot" (Alternate)]
        Ctrl -> Ctrl: Memicu "Mengajukan Eskalasi Pemasangan"\n(Extend UC_VT03)
        Ctrl --> Form: Menampilkan form eskalasi
    else [Kategori Status "Reguler"]
        Ctrl -> DB: Memproses dan menyimpan data prospek
        activate DB
        DB --> Ctrl: Konfirmasi data tersimpan
        deactivate DB
        Ctrl --> Form: Status sukses
        Form --> Sales: Menampilkan notifikasi sukses
    end
end

deactivate Ctrl
deactivate Form
deactivate Sales
@enduml