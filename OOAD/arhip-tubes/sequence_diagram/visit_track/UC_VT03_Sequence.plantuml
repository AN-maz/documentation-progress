@startuml
autonumber
skinparam style strictuml

actor Sales
boundary "Form Eskalasi" as Form
control "Control Eskalasi" as Ctrl
entity "Database VisitTrack" as DB
boundary "API Sistem Operasional" as API

activate Sales
Ctrl -> Form: Menampilkan formulir eskalasi pemasangan\n(Dari Extend UC_VT02)
activate Ctrl
activate Form
Form --> Sales: Menampilkan form ke layar pengguna
deactivate Ctrl

Sales -> Form: Melengkapi data pendukung pelanggan
Sales -> Form: Menekan tombol "Eskalasi ke Tim Teknis"
Form -> Ctrl: Mengirim request pengajuan eskalasi
activate Ctrl
Ctrl -> Ctrl: Memverifikasi kelengkapan data pendukung

alt [Data Pendukung Wajib Tidak Lengkap (Exception)]
    Ctrl --> Form: Menunda pengiriman tiket
    Form --> Sales: Menampilkan pesan peringatan (Data Kurang)
    Sales -> Form: Melengkapi data pendukung yang kurang
else [Data Lengkap / Ya]
    Ctrl -> DB: Mengambil data pelanggan dan lokasi kunjungan
    activate DB
    DB --> Ctrl: Mengembalikan data & lokasi
    deactivate DB
    Ctrl -> Ctrl: Membuat tiket pemasangan
    
    Ctrl -> API: Mengirimkan tiket ke Sistem Operasional
    activate API
    API --> Ctrl: Mengembalikan response penerimaan tiket
    deactivate API
    
    Ctrl -> DB: Memperbarui status prospek (Eskalasi Terkirim)
    activate DB
    DB --> Ctrl: Konfirmasi status diupdate
    deactivate DB
    
    Ctrl --> Form: Status pengiriman tiket sukses
    Form --> Sales: Menampilkan notifikasi berhasil
end

deactivate Ctrl
deactivate Form
deactivate Sales
@enduml