@startuml
autonumber
skinparam style strictuml

actor Pelanggan
boundary "Menu Pembayaran" as Form
control "Control Tagihan" as Ctrl
entity "Database Tagihan" as DB

activate Pelanggan
Pelanggan -> Form: Memilih menu "Bayar Internet"
activate Form
Form -> Ctrl: Request data tagihan
activate Ctrl
Ctrl -> DB: Mencari data pelanggan dan tagihan
activate DB
DB --> Ctrl: Mengembalikan hasil pencarian
deactivate DB

alt [Data Tagihan Tidak Ditemukan]
    Ctrl --> Form: Mengirim pesan kesalahan (Data Kosong)
    Form --> Pelanggan: Menampilkan pesan kesalahan & Batal
else [Data Tagihan Ditemukan]
    Ctrl --> Form: Mengirim data tagihan aktif
    Form --> Pelanggan: Menampilkan informasi tagihan aktif
    
    Pelanggan -> Form: Memilih metode pembayaran (C-Pay)
    Form -> Ctrl: Memproses pilihan C-Pay
    Ctrl -> DB: Memverifikasi ketersediaan saldo C-Pay
    activate DB
    DB --> Ctrl: Mengembalikan informasi saldo
    deactivate DB
    
    alt [Saldo C-Pay Tidak Mencukupi]
        Ctrl --> Form: Mengirim peringatan saldo kurang
        Form --> Pelanggan: Memicu alur pengisian saldo (Extend UC_SA02)
    else [Saldo Mencukupi]
        Ctrl -> DB: Memotong saldo & Memperbarui status tagihan menjadi "Lunas"
        activate DB
        DB --> Ctrl: Konfirmasi transaksi berhasil
        deactivate DB
        Ctrl --> Form: Mengirim bukti transaksi
        Form --> Pelanggan: Menampilkan bukti transaksi
    end
end

deactivate Ctrl
deactivate Form
deactivate Pelanggan
@enduml