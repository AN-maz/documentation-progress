@startuml
autonumber
skinparam style strictuml

actor Pelanggan
boundary "Menu Hotel" as Form
control "Control Reservasi" as Ctrl
entity "Database Kamar" as DB

activate Pelanggan
Pelanggan -> Form: Memasukkan kriteria pencarian kamar hotel
activate Form
Form -> Ctrl: Mengirim kriteria pencarian
activate Ctrl
Ctrl -> DB: Mencari kamar yang tersedia
activate DB
DB --> Ctrl: Mengembalikan daftar kamar
deactivate DB
Ctrl --> Form: Meneruskan ke layar
Form --> Pelanggan: Menampilkan daftar kamar yang tersedia
deactivate Ctrl

Pelanggan -> Form: Memilih kamar dan melengkapi data reservasi
Form -> Ctrl: Mengirim request booking sementara
activate Ctrl
Ctrl -> DB: Memverifikasi ketersediaan kamar secara real-time
activate DB
DB --> Ctrl: Mengembalikan ketersediaan stok
deactivate DB

alt [Kamar Tidak Tersedia / Penuh]
    Ctrl --> Form: Mengembalikan status kamar habis
    Form --> Pelanggan: Menampilkan pemberitahuan & diminta memilih kamar lain
else [Kamar Tersedia]
    Ctrl --> Form: Konfirmasi slot kamar diamankan
    Form --> Pelanggan: Menampilkan tagihan reservasi
    Pelanggan -> Form: Melakukan pembayaran menggunakan C-Pay
    Form -> Ctrl: Memproses perintah pembayaran C-Pay
    Ctrl -> DB: Memverifikasi saldo C-Pay
    activate DB
    DB --> Ctrl: Mengembalikan sisa saldo
    deactivate DB
    
    alt [Saldo C-Pay Tidak Mencukupi]
        Ctrl --> Form: Status saldo kurang
        Form --> Pelanggan: Memicu alur pengisian saldo (Extend UC_SA02)
    else [Saldo Mencukupi]
        Ctrl -> DB: Memotong saldo pelanggan & mencatat booking
        activate DB
        DB --> Ctrl: Konfirmasi transaksi sukses
        deactivate DB
        Ctrl -> DB: Menerbitkan e-voucher hotel
        activate DB
        DB --> Ctrl: File e-voucher
        deactivate DB
        Ctrl --> Form: Mengirim data e-voucher
        Form --> Pelanggan: Menampilkan e-voucher hotel (Bukti Reservasi)
    end
end

deactivate Ctrl
deactivate Form
deactivate Pelanggan
@enduml