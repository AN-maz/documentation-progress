@startuml
autonumber
skinparam style strictuml

actor Logistik
boundary "Form PR" as Form
control "Controller Pembelian" as Ctrl
entity "Database Finance" as DB

activate Ctrl
Ctrl -> Ctrl: Mendeteksi stok barang di bawah batas minimum
Ctrl --> Form: Membuka formulir Purchase Request
activate Form
Form --> Logistik: Menampilkan form ke layar pengguna
deactivate Ctrl

activate Logistik
Logistik -> Form: Mengisi rincian barang yang dibutuhkan
Logistik -> Form: Mengirimkan permohonan pembelian
Form -> Ctrl: Meneruskan data pengajuan
activate Ctrl

Ctrl -> Ctrl: Memverifikasi kelengkapan data pengajuan

alt [Data tidak lengkap / Tidak]
    Ctrl --> Form: Menolak pengiriman form
    Form --> Logistik: Meminta pengguna melengkapi informasi
else [Data lengkap / Ya]
    Ctrl -> DB: Meneruskan pengajuan ke dashboard Finance
    activate DB
    DB --> Ctrl: Mengonfirmasi penerimaan pengajuan
    deactivate DB
    Ctrl --> Form: Mengonfirmasi status pengajuan berhasil
    Form --> Logistik: Menampilkan notifikasi persetujuan
end

deactivate Ctrl
deactivate Form
deactivate Logistik
@enduml