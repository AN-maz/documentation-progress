@startuml
autonumber
skinparam style strictuml

actor Teknisi
boundary "Form Detail Tiket" as Form
control "Controller Instalasi" as Ctrl
entity "Database Operasional" as DB

activate Teknisi
Teknisi -> Form: Menyelesaikan instalasi fisik & Membuka detail tiket
activate Form
Teknisi -> Form: Mengubah status pekerjaan menjadi "Selesai"
Form -> Ctrl: Mengirim permintaan perubahan status
activate Ctrl

Ctrl -> Ctrl: Memvalidasi kelengkapan data instalasi

alt [Data belum lengkap / Tidak]
    Ctrl --> Form: Menolak perubahan status & meminta kelengkapan
    Form --> Teknisi: Menampilkan peringatan data kurang
    Teknisi -> Form: Melengkapi data instalasi
else [Data lengkap / Ya]
    Ctrl -> DB: Menyimpan data penyelesaian instalasi
    activate DB
    DB --> Ctrl: Konfirmasi penyimpanan berhasil
    deactivate DB
    
    Ctrl -> DB: Meneruskan tiket ke antrean NOC untuk aktivasi
    activate DB
    DB --> Ctrl: Konfirmasi tiket dipindahkan
    deactivate DB
    
    Ctrl --> Form: Status tiket berhasil ditutup
    Form --> Teknisi: Menampilkan notifikasi sukses
end

deactivate Ctrl
deactivate Form
deactivate Teknisi
@enduml