@startuml
autonumber
skinparam style strictuml

actor Finance
boundary "Dashboard Finance" as Form
control "Controller Pembelian" as Ctrl
entity "Database Finance" as DB

activate Finance
Finance -> Form: Membuka daftar Purchase Request
activate Form
Form -> Ctrl: Mengambil detail pengajuan
activate Ctrl
Ctrl -> DB: Mengambil rincian kebutuhan & estimasi biaya
activate DB
DB --> Ctrl: Mengembalikan rincian
deactivate DB
Ctrl --> Form: Menampilkan rincian pengajuan
deactivate Ctrl

Finance -> Finance: Melakukan evaluasi terhadap pengajuan
Finance -> Form: Mengirimkan hasil keputusan
Form -> Ctrl: Memproses keputusan validasi anggaran
activate Ctrl

alt [Anggaran Tidak Mencukupi / Ditolak]
    Ctrl -> DB: Menandai pengajuan ditolak beserta alasan
    activate DB
    DB --> Ctrl: Konfirmasi status ditolak
    deactivate DB
    Ctrl --> Form: Menampilkan status ditolak
else [Butuh Revisi]
    Ctrl --> Form: Mengembalikan pengajuan ke Logistik
    Form --> Finance: Meminta revisi data pengajuan
else [Anggaran Sesuai / Disetujui]
    Ctrl -> DB: Memperbarui status pengajuan menjadi disetujui
    activate DB
    DB --> Ctrl: Konfirmasi status disetujui
    deactivate DB
    Ctrl -> DB: Mengirimkan notifikasi kepada Logistik
    activate DB
    DB --> Ctrl: Notifikasi terkirim
    deactivate DB
    Ctrl --> Form: Konfirmasi persetujuan berhasil
    Form --> Finance: Menampilkan status selesai
end

deactivate Ctrl
deactivate Form
deactivate Finance
@enduml